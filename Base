<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>Konjugationstrainer</title>
<style>
  body { font-family: Arial; padding: 20px; max-width: 600px; }
  .task { font-size: 22px; margin: 20px 0; }
  .correct { color: green; }
  .wrong { color: red; }
  .hint { color: orange; }
  input { padding: 8px; font-size: 16px; width: 200px; }
</style>
</head>
<body>

<h2>Konjugationstrainer</h2>

<label>Verb:
<select id="verb">
  <option value="regere">regere</option>
  <option value="facere">facere</option>
  <option value="venire">venire</option>
  <option value="parare">parare</option>
  <option value="accipere">accipere</option>
</select>
</label>

<h3>Filter</h3>

<label><input type="checkbox" value="Aktiv" checked> Aktiv</label>
<label><input type="checkbox" value="Passiv" checked> Passiv</label>

<br><br>

<label><input type="checkbox" value="0" checked> 1. Sg.</label>
<label><input type="checkbox" value="1" checked> 2. Sg.</label>
<label><input type="checkbox" value="2" checked> 3. Sg.</label>
<label><input type="checkbox" value="3" checked> 1. Pl.</label>
<label><input type="checkbox" value="4" checked> 2. Pl.</label>
<label><input type="checkbox" value="5" checked> 3. Pl.</label>

<br><br>

<button onclick="generate()">Neue Aufgabe</button>

<div class="task" id="task"></div>

<input type="text" id="answer" placeholder="Antwort eingeben">
<br><br>

<button onclick="check()">Überprüfen</button>

<div id="feedback"></div>
<div>Punkte: <span id="score">0</span></div>

<script>
let current = {};
let score = 0;

const persons = ["1. Sg.","2. Sg.","3. Sg.","1. Pl.","2. Pl.","3. Pl."];

const verbs = {
  regere: {
    aktiv: ["rego","regis","regit","regimus","regitis","regunt"],
    passiv: ["regor","regeris","regitur","regimur","regimini","reguntur"]
  },
  facere: {
    aktiv: ["facio","facis","facit","facimus","facitis","faciunt"],
    passiv: ["facior","faceris","facitur","facimur","facimini","faciuntur"]
  },
  venire: {
    aktiv: ["venio","venis","venit","venimus","venitis","veniunt"],
    passiv: ["venior","veniris","venitur","venimur","venimini","veniuntur"]
  },
  parare: {
    aktiv: ["paro","paras","parat","paramus","paratis","parant"],
    passiv: ["paror","pararis","paratur","paramur","paramini","parantur"]
  },
  accipere: {
    aktiv: ["accipio","accipis","accipit","accipimus","accipitis","accipiunt"],
    passiv: ["accipior","acciperis","accipitur","accipimur","accipimini","accipiuntur"]
  }
};

function normalize(input) {
  return input.trim().toLowerCase();
}

function getChecked(selector) {
  return Array.from(document.querySelectorAll(selector + ":checked"))
              .map(e => e.value);
}

function random(arr) {
  return arr[Math.floor(Math.random() * arr.length)];
}

function generate() {
  const verb = document.getElementById("verb").value;
  const genera = getChecked('input[value="Aktiv"], input[value="Passiv"]');
  const indices = getChecked('input[value="0"], input[value="1"], input[value="2"], input[value="3"], input[value="4"], input[value="5"]');

  if (genera.length === 0 || indices.length === 0) {
    alert("Bitte Filter auswählen!");
    return;
  }

  const gen = random(genera);
  const index = random(indices);

  current = {
    verb,
    gen,
    index: Number(index),
    solution: verbs[verb][gen.toLowerCase()][index]
  };

  document.getElementById("task").innerText =
    `${verb} – ${persons[index]} Präsens ${gen}`;

  document.getElementById("feedback").innerText = "";
  document.getElementById("answer").value = "";
  document.getElementById("answer").focus();
}

function check() {
  const input = normalize(document.getElementById("answer").value);

  if (!input) return;

  const correct = current.solution;

  if (input === correct) {
    document.getElementById("feedback").innerHTML =
      "<span class='correct'>Richtig!</span>";
    score++;
  } else {
    let hint = "";

    // einfache, zuverlässige Diagnose:
    const aktivForm = verbs[current.verb].aktiv[current.index];
    const passivForm = verbs[current.verb].passiv[current.index];

    if (input === aktivForm && current.gen === "Passiv") {
      hint = "→ Aktiv statt Passiv";
    } else if (input === passivForm && current.gen === "Aktiv") {
      hint = "→ Passiv statt Aktiv";
    }

    document.getElementById("feedback").innerHTML =
      `<span class='wrong'>Falsch!</span> ${hint ? "<span class='hint'>" + hint + "</span>" : ""}<br>Richtig: ${correct}`;
  }

  document.getElementById("score").innerText = score;

  setTimeout(generate, 1500);
}

// Enter = prüfen
document.getElementById("answer").addEventListener("keypress", function(e) {
  if (e.key === "Enter") check();
});
</script>

</body>
</html>
